{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": ["/favicon.ico", "/index.html", "/*.css", "/*.js"]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/assets/**"]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "nasa-apod",
      "urls": ["https://api.nasa.gov/planetary/apod**"],
      "cacheConfig": {
        "maxSize": 50,
        "maxAge": "1d",
        "strategy": "performance"
      }
    },
    {
      "name": "nasa-mars",
      "urls": ["https://api.nasa.gov/mars-photos/**"],
      "cacheConfig": {
        "maxSize": 100,
        "maxAge": "6h",
        "strategy": "performance"
      }
    }
  ]
}